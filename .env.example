# --- Servidor local ---
PORT=4000

# --- Pocket TTS (local, clonación de voz) ---
# Motor: kyutai-labs/pocket-tts. Corre en CPU (Apple Silicon).
# Python con pocket-tts instalado (recomendado venv): pip install pocket-tts
PYTHON_BIN=python3
# idiomas: english, french, german, portuguese, italian, spanish
POCKET_TTS_LANGUAGE=spanish
# wav de referencia por defecto (en assets/voces_referencia) si el guion no
# define `archivo_voz_clon`. Déjalo vacío para exigirlo en cada guion.
POCKET_TTS_DEFAULT_VOICE_FILE=
# Modo prueba: genera un tono SIN cargar el modelo (valida el pipeline). 1 para activar.
POCKET_TTS_MOCK=0
# Temperatura de muestreo (vacío = default del modelo, 0.7). Más alta = voz más viva.
POCKET_TTS_TEMPERATURE=

# Voces (campo `archivo_voz_clon` del guion):
#  - Catálogo (SIN login): un nombre como alba, giovanni, lola, jean, vera, eve…
#    (o una URL hf://). Funciona sin autenticación.
#  - Clonar TU voz (modelo GATED): un archivo .wav en assets/voces_referencia.
#    Requiere: 1) aceptar términos en https://huggingface.co/kyutai/pocket-tts
#              2) autenticarte -> `.venv/bin/hf auth login`  (o define HF_TOKEN aquí)
# HF_TOKEN=hf_xxx

# --- FFmpeg ---
# Déjalo como "ffmpeg" si está en el PATH.
# En Apple Silicon con Homebrew suele ser: /opt/homebrew/bin/ffmpeg
FFMPEG_PATH=ffmpeg

# --- Render ---
RENDER_FPS=30
RENDER_CRF=20
RENDER_PRESET=medium
# Cola de vídeo (s) tras acabar la voz en cada plano, para que el corte no sea
# brusco. La imagen sigue viva (avatar flota); el audio se rellena con silencio.
RENDER_TAIL_PADDING=0.6

# --- Avatar flotante ---
AVATAR_BOX=600
AVATAR_BOUNCE_AMP=20
AVATAR_BOUNCE_FREQ=1.5

# --- Música de fondo ---
# Pon archivos de audio en assets/musica y elígelos por plano (directiva
# `musica:` o el selector del editor). Un plano sin `musica` CONTINÚA la pista
# del anterior; `musica: none` la corta; otro archivo cambia de pista.
MUSIC_VOLUME=0.18   # 0..1, ganancia de la música bajo la voz
MUSIC_FADE=1.2      # s de fundido al entrar/salir cada pista

# --- Descargas automáticas (scripts/descargar.mjs) ----------------------------
# Clave gratis de la API de Pixabay para auto-bajar los vídeos del "carrito"
# (descargas.json). Sin ella solo se bajan enlaces directos a archivo. -> pnpm descargar
PIXABAY_API_KEY=
# Nº de vídeos candidatos que baja por card (para elegir el que más pegue).
DESCARGAS_CANDIDATOS=4

# --- Subida a Google Drive (scripts/subir-drive.mjs, vía rclone) --------------
# Configura el remote una sola vez con `rclone config` (tipo: drive), luego:
#   pnpm subir            # sube outputs/*.mp4
# DRIVE_AUTO=1 sube el mp4 automáticamente al terminar cada render.
RCLONE_PATH=rclone        # ruta al binario de rclone (si no está en el PATH)
DRIVE_REMOTE=drive        # nombre del remote de rclone (Drive)
DRIVE_FOLDER=ContentCreator   # carpeta destino dentro de ese Drive
DRIVE_AUTO=0              # 1 = subir automáticamente tras cada render

# --- Publicar en redes (Instagram Reels + TikTok, APIs nativas gratis) -------
# Los TOKENS no van aquí: se guardan en social.config.json (Configuración → Publicar).
# IG usa la Graph API; el vídeo se sube a un host temporal (litterbox) para que IG
# lo descargue. TikTok sube a borrador y tú publicas con un toque en la app.
SOCIAL_DEFAULT=instagram,tiktok     # redes marcadas por defecto en «Publicar»
IG_GRAPH_VERSION=v21.0              # versión de la Graph API de Meta

# --- Correo entrante/saliente (opcional) --------------------------------------
# Lectura IMAP (bandeja de newsletters para inspirar guiones) y envío SMTP de
# avisos ("vídeo listo en Drive"). Las CREDENCIALES no van aquí: se guardan en
# mail.config.json (copia mail.config.example.json). Usa una CONTRASEÑA DE
# APLICACIÓN, nunca la principal. Solo define esto si tu proveedor no sigue el
# patrón imap.<dominio> / smtp.<dominio>:
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=465               # 465 = SSL directo · 587 = STARTTLS

# --- Subtítulos automáticos ---------------------------------------------------
# Solo se pintan si la disposición tiene un elemento "subtitle" (define la caja).
# El texto del plano se trocea y reparte sobre la voz. Render vía rsvg-convert
# (brew install librsvg) -> PNG -> overlay; NO necesita drawtext/freetype.
RSVG_PATH=rsvg-convert          # binario de rsvg-convert (librsvg)
SUBTITLE_REVEAL=wipe           # wipe = se "escribe" (cortina L->R) · none = de golpe
SUBTITLE_HOLD=0.5              # s que el texto completo queda fijo tras la cortina
SUBTITLE_MAX_WORDS=4            # palabras por trozo de subtítulo
SUBTITLE_FONT=Helvetica, Arial, sans-serif
SUBTITLE_FONT_SIZE=60          # px sobre el lienzo 1080
SUBTITLE_WEIGHT=800            # grosor de fuente (100–900)
SUBTITLE_COLOR=#ffffff         # color del texto
SUBTITLE_STROKE_COLOR=#000000  # color del contorno
SUBTITLE_STROKE_WIDTH=7        # grosor del contorno (px)
SUBTITLE_LINE_HEIGHT=1.18      # interlínea (×fontSize)
SUBTITLE_UPPERCASE=false       # true = subtítulos en MAYÚSCULAS
